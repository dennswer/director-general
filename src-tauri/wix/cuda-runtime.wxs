<?xml version="1.0" encoding="UTF-8"?>
<!--
  Bundle the CUDA runtime DLLs alongside the app executable so the MSI is
  self-contained on any machine with an NVIDIA GPU + recent driver — even
  without a separate CUDA Toolkit install.

  Source paths are relative to this .wxs file. The CI workflow copies the
  three DLLs from $env:CUDA_PATH\bin into ./cuda-bin/ before invoking
  `tauri build`, so candle.exe can resolve them at WiX compile time without
  depending on environment variables (which were unreliable across the
  npm → cargo → tauri-bundler → candle invocation chain).
-->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Fragment>
    <DirectoryRef Id="INSTALLDIR">
      <Component Id="CudaRuntimeDlls" Guid="3F5A8A1C-1F4B-4F4F-9F1D-1C2B3A4E5F60" Win64="yes">
        <File Id="CudaRtDll"
              Source="..\cuda-bin\cudart64_12.dll"
              KeyPath="yes"/>
        <File Id="CublasDll"
              Source="..\cuda-bin\cublas64_12.dll"/>
        <File Id="CublasLtDll"
              Source="..\cuda-bin\cublasLt64_12.dll"/>
      </Component>
    </DirectoryRef>

    <ComponentGroup Id="CudaRuntimeGroup">
      <ComponentRef Id="CudaRuntimeDlls"/>
    </ComponentGroup>
  </Fragment>
</Wix>
